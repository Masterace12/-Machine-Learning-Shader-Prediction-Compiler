  <releases>
    <release version="3.0.0" date="2024-01-15">
      <description>
        <p>Major release with Steam Deck optimization and Flatpak support:</p>
        <ul>
          <li>Complete Steam Deck hardware integration with LCD/OLED model detection</li>
          <li>Thermal and battery-aware resource management</li>
          <li>Gaming mode detection and automatic resource throttling</li>
          <li>Flatpak packaging with proper sandboxing and permissions</li>
          <li>Enhanced ML prediction models optimized for RDNA2 GPU</li>
          <li>P2P shader sharing network with reputation system</li>
          <li>Steam compatibility tool integration</li>
          <li>Improved security with signature verification and privacy protection</li>
        </ul>
      </description>
    </release>
    <release version="2.1.0" date="2023-12-01">
