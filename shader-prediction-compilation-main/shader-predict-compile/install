# MAIN INSTALLER FUNCTIONS (ENHANCED)
# =============================================================================

# Check if running as root
check_permissions() {
    if [[ $EUID -eq 0 ]]; then
        log_error "Do not run this installer as root!"
        log_info "The installer will ask for sudo when needed."
        exit 1
    fi
}

# Detect Steam Deck model with enhanced detection
detect_steam_deck() {
    log_header "🔍 Detecting Steam Deck Configuration"
    
    # Check if this is a Steam Deck
    if [ ! -f "/sys/devices/virtual/dmi/id/product_name" ] || \
       ! grep -q "Jupiter" /sys/devices/virtual/dmi/id/product_name 2>/dev/null; then
        log_warning "This doesn't appear to be a Steam Deck"
        read -p "Continue installation anyway? [y/N]: " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            log_info "Installation cancelled"
            exit 0
        fi
    fi
    
    # Enhanced model detection
    MODEL="Unknown"
    if [ -f "/sys/class/drm/card0/device/apu_model" ]; then
        APU_MODEL=$(cat /sys/class/drm/card0/device/apu_model 2>/dev/null || echo "unknown")
        case $APU_MODEL in
            *"Van Gogh"*) MODEL="LCD" ;;
            *"Phoenix"*) MODEL="OLED" ;;
        esac
    elif [ -f "/sys/devices/virtual/dmi/id/product_name" ]; then
        # Fallback detection
        PRODUCT=$(cat /sys/devices/virtual/dmi/id/product_name 2>/dev/null)
        if [[ "$PRODUCT" == *"Jupiter"* ]]; then
            MODEL="LCD"  # Default to LCD for older detection
        fi
    fi
    
    # SteamOS version
    STEAMOS_VERSION="Unknown"
    if [ -f "/etc/os-release" ]; then
        STEAMOS_VERSION=$(grep VERSION_ID /etc/os-release | cut -d'"' -f2)
    fi
    
    log_info "Steam Deck Model: ${MODEL}"
    log_info "SteamOS Version: ${STEAMOS_VERSION}"
    
    # Version compatibility check
    if [[ "$STEAMOS_VERSION" < "3.7" ]] && [[ "$STEAMOS_VERSION" != "Unknown" ]]; then
        log_warning "SteamOS $STEAMOS_VERSION may not be fully compatible"
        log_info "Recommended: SteamOS 3.7.13 or later"
        read -p "Continue anyway? [y/N]: " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 0
        fi
    fi
    
    echo
}

# Enhanced dependency checking with auto-installation
check_dependencies() {
    log_header "📦 Checking and Installing Dependencies"
    
    local missing_system=()
    local missing_python=()
    
    # Check Python version
    if ! command -v python3 &>/dev/null; then
        missing_system+=("python")
    else
        PYTHON_VERSION=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}")')
        log_info "Python version: $PYTHON_VERSION"
        
        PYTHON_MAJOR=$(python3 -c 'import sys; print(sys.version_info.major)')
        PYTHON_MINOR=$(python3 -c 'import sys; print(sys.version_info.minor)')
        if [ "$PYTHON_MAJOR" -lt 3 ] || ([ "$PYTHON_MAJOR" -eq 3 ] && [ "$PYTHON_MINOR" -lt 7 ]); then
            log_warning "Python $PYTHON_VERSION detected - 3.7+ recommended"
        fi
    fi
    
    # Check GTK bindings
    if ! python3 -c "import gi; gi.require_version('Gtk', '3.0')" &>/dev/null 2>&1; then
        missing_system+=("python-gobject")
    fi
    
    # Check Python packages
    if ! python3 -c "import psutil" &>/dev/null 2>&1; then
        missing_python+=("psutil>=5.8.0")
    fi
    
    if ! python3 -c "import numpy" &>/dev/null 2>&1; then
        missing_python+=("numpy>=1.20.0")
    fi
    
    # Install system packages
    if [ ${#missing_system[@]} -ne 0 ]; then
        log_info "Installing system packages: ${missing_system[*]}"
        
        if command -v pacman &>/dev/null; then
            # Fix pacman keyring issues first
            log_info "Ensuring pacman keyring is up to date..."
            sudo pacman-key --init &>/dev/null || true
            sudo pacman-key --populate &>/dev/null || true
            
            # Update and install
            sudo pacman -Sy --noconfirm "${missing_system[@]}" || {
                log_warning "Pacman installation failed, trying alternative methods..."
                
                # Try flatpak as fallback
                if command -v flatpak &>/dev/null; then
                    log_info "Trying flatpak runtime installation..."
                    flatpak install --user -y org.freedesktop.Platform.GL.default//22.08 &>/dev/null || true
                fi
            }
        else
            log_error "Package manager not found"
            log_info "Please install these packages manually: ${missing_system[*]}"
        fi
    fi
    
    # Install Python packages
    if [ ${#missing_python[@]} -ne 0 ]; then
        log_info "Installing Python packages: ${missing_python[*]}"
        
        # Ensure pip is available
        if ! python3 -m pip --version &>/dev/null; then
            log_info "Installing pip..."
            if command -v curl &>/dev/null; then
                curl -sS https://bootstrap.pypa.io/get-pip.py | python3 - --user || {
                    log_warning "Could not install pip automatically"
                }
            fi
        fi
        
        # Install packages
        python3 -m pip install --user --no-warn-script-location "${missing_python[@]}" || {
            log_warning "Some Python packages failed to install"
            log_info "The application will run with reduced functionality"
        }
    fi
    
    # Final validation
    local all_good=true
    
    if ! python3 -c "import gi; gi.require_version('Gtk', '3.0')" &>/dev/null 2>&1; then
        log_error "GTK bindings not available - GUI will not work"
        all_good=false
    fi
    
    if [ "$all_good" = true ]; then
        log_success "All dependencies satisfied"
    else
        log_error "Critical dependencies missing"
        log_info "Installation cannot continue"
        exit 1
    fi
    
    echo
}

# Install application with enhanced error handling
install_application() {
    log_header "🚀 Installing Application"
    
    # Create directories
    sudo mkdir -p "$INSTALL_DIR" || {
        log_error "Cannot create installation directory"
        exit 1
    }
    sudo mkdir -p "$(dirname "$DESKTOP_FILE")"
    sudo mkdir -p "$(dirname "$SYSTEMD_SERVICE")"
    
    # Copy application files with verification
    log_info "Copying application files..."
    
    for dir in src ui config; do
        if [ -d "$CURRENT_DIR/$dir" ]; then
            sudo cp -r "$CURRENT_DIR/$dir" "$INSTALL_DIR/" || {
                log_error "Failed to copy $dir directory"
                exit 1
            }
        else
            log_error "Required directory missing: $dir"
            exit 1
        fi
    done
    
    # Copy additional files
    for file in requirements.txt README.md; do
        if [ -f "$CURRENT_DIR/$file" ]; then
            sudo cp "$CURRENT_DIR/$file" "$INSTALL_DIR/"
        fi
    done
    
    # Copy optional files
    for file in gaming_mode_launcher.sh auto_launcher.sh launcher.sh icon.png; do
        if [ -f "$CURRENT_DIR/$file" ]; then
            sudo cp "$CURRENT_DIR/$file" "$INSTALL_DIR/"
        fi
    done
    
    # Create enhanced launcher script
    sudo tee "$INSTALL_DIR/launcher.sh" > /dev/null << EOF
#!/bin/bash
# Enhanced launcher with error handling

cd /opt/$APP_NAME

# Set up environment
export PYTHONPATH="/opt/$APP_NAME/src:\$PYTHONPATH"
export MESA_VK_DEVICE_SELECT="1002:163f"
export RADV_PERFTEST="aco,nggc"

# Create log directory
mkdir -p "\$HOME/.cache/$APP_NAME"

# Check if running in Gaming Mode
if [ -n "\$GAMESCOPE_WAYLAND_DISPLAY" ]; then
    # Gaming Mode specific settings
    export QT_SCALE_FACTOR=1.5
    export GDK_SCALE=1.5
    export SDL_VIDEODRIVER=x11
    
    # Use Gaming Mode launcher if available
    if [ -f "gaming_mode_launcher.sh" ]; then
        exec ./gaming_mode_launcher.sh "\$@"
    fi
fi

# Regular desktop mode
python3 ui/main_window.py "\$@" 2>&1 | tee -a "\$HOME/.cache/$APP_NAME/launcher.log"
EOF
    
    sudo chmod +x "$INSTALL_DIR/launcher.sh"
    sudo chmod +x "$INSTALL_DIR/ui/main_window.py"
    sudo chmod +x "$INSTALL_DIR/src/background_service.py"
    
    log_success "Application files installed"
    echo
}

# Create enhanced desktop entry
create_desktop_entry() {
    log_header "🖥️  Creating Desktop Integration"
    
    sudo tee "$DESKTOP_FILE" > /dev/null << EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=Shader Predictive Compiler
GenericName=Shader Optimizer
Comment=Enhance shader compilation for Steam games on Steam Deck
Icon=$INSTALL_DIR/icon.png
Exec=$INSTALL_DIR/launcher.sh
Path=$INSTALL_DIR
Terminal=false
Categories=Game;Utility;System;
Keywords=shader;steam;deck;fossilize;compile;performance;optimization;gaming;
StartupNotify=true
StartupWMClass=shader-predict-compile

# Steam Deck specific entries
X-Steam-Library-CapsuleImage=$INSTALL_DIR/icon.png
X-Steam-Controller-Template=Desktop
X-Steam-Library-HeroImage=$INSTALL_DIR/icon.png
X-Steam-Library-GridImage=$INSTALL_DIR/icon.png

# Gaming Mode compatibility
X-KDE-RunOnDiscreteGpu=false
X-KDE-SubstituteUID=false

# Quick actions
Actions=Settings;Status;Stop;

[Desktop Action Settings]
Name=Open Settings
Exec=$INSTALL_DIR/launcher.sh --settings
Icon=preferences-system

[Desktop Action Status]
Name=Check Status
Exec=$INSTALL_DIR/launcher.sh --status
Icon=dialog-information

[Desktop Action Stop]
Name=Stop Service
Exec=systemctl --user stop $APP_NAME.service
Icon=process-stop
EOF
    
    log_success "Desktop entry created"
    echo
}

# Create enhanced systemd service
create_systemd_service() {
    log_header "⚙️  Setting Up Background Service"
    
    sudo tee "$SYSTEMD_SERVICE" > /dev/null << EOF
[Unit]
Description=Shader Predictive Compiler Background Service
After=steam.service multi-user.target
Wants=steam.service

[Service]
Type=simple
User=deck
Group=deck
Environment=PYTHONPATH=/opt/$APP_NAME/src
Environment=MESA_VK_DEVICE_SELECT=1002:163f
Environment=RADV_PERFTEST=aco,nggc
ExecStart=$INSTALL_DIR/src/background_service.py
Restart=on-failure
RestartSec=30
StandardOutput=journal
StandardError=journal

# Resource limits optimized for Steam Deck
MemoryMax=$([ "$MODEL" = "OLED" ] && echo "2560M" || echo "2048M")
CPUQuota=$([ "$MODEL" = "OLED" ] && echo "60%" || echo "50%")

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/home/deck/.cache /home/deck/.config

[Install]
WantedBy=multi-user.target
EOF
    
    # Reload and enable service
    sudo systemctl daemon-reload
    sudo systemctl enable "$APP_NAME.service"
    
    log_success "Background service configured"
    echo
}

# Set up user configuration with model-specific optimizations
setup_user_config() {
    log_header "👤 Setting Up User Configuration"
    
    # Create user directories
    mkdir -p "$HOME/.config/$APP_NAME"
    mkdir -p "$HOME/.cache/$APP_NAME"
    
    # Copy default configuration if it exists
    if [ -f "$CURRENT_DIR/config/default_settings.json" ]; then
        cp "$CURRENT_DIR/config/default_settings.json" "$HOME/.config/$APP_NAME/settings.json"
    fi
    
    # Create model-specific optimizations config
    cat > "$HOME/.config/$APP_NAME/optimizations.json" << EOF
{
    "steam_deck_model": "$MODEL",
    "steamos_version": "$STEAMOS_VERSION",
    "detected_at": "$(date -Iseconds)",
    "installation_method": "integrated_fixes_installer",
    "optimizations": {
        "max_parallel_compiles": $([ "$MODEL" = "OLED" ] && echo 6 || echo 4),
        "memory_limit_mb": $([ "$MODEL" = "OLED" ] && echo 2560 || echo 2048),
        "cpu_quota_percent": $([ "$MODEL" = "OLED" ] && echo 60 || echo 50),
        "enable_enhanced_features": $([ "$MODEL" = "OLED" ] && echo true || echo false),
        "target_architecture": "znver2"
    }
}
EOF
    
    log_success "User configuration created with $MODEL optimizations"
    echo
}

# Enhanced Steam integration
setup_steam_integration() {
    log_header "🎮 Configuring Steam Integration"
    
    if [ -d "$HOME/.steam" ]; then
        # Create fossilize config directory
        mkdir -p "$HOME/.config/fossilize"
        
        # Create optimized fossilize configuration
        cat > "$HOME/.config/fossilize/config.json" << EOF
{
    "enable_pipeline_cache": true,
    "shader_cache_dir": "$HOME/.cache/$APP_NAME/fossilize",
    "parallel_compile_threads": $([ "$MODEL" = "OLED" ] && echo 6 || echo 4),
    "optimization_level": 2,
    "target_architecture": "znver2",
    "predictive_compilation": true,
    "integration_tool": "$APP_NAME",
    "steam_deck_model": "$MODEL",
    "memory_limit_mb": $([ "$MODEL" = "OLED" ] && echo 2560 || echo 2048)
}
EOF
        
        log_success "Steam integration configured for $MODEL model"
    else
        log_warning "Steam directory not found - integration will be set up on first run"
    fi
    echo
}

# Installation completion with enhanced summary
installation_complete() {
    log_header "✅ Installation Complete!"
    
    echo -e "${GREEN}${BOLD}Shader Predictive Compiler has been successfully installed!${NC}"
    echo
    echo "🔧 ${BOLD}GitHub Download Issues Fixed:${NC}"
    echo "  • Line endings converted (CRLF → LF)"
    echo "  • File permissions corrected"
    echo "  • Shebang lines validated"
    echo "  • Missing files generated"
    echo "  • Symlinks created"
    echo
    echo "🎮 ${BOLD}How to use:${NC}"
    echo "  • Gaming Mode: Library → Non-Steam → Shader Predictive Compiler"
    echo "  • Desktop Mode: Applications → Games → Shader Predictive Compiler"
    echo "  • Command line: $INSTALL_DIR/launcher.sh"
    echo
    echo "⚙️  ${BOLD}Background Service:${NC}"
    echo "  • Start now: sudo systemctl start $APP_NAME"
    echo "  • Auto-start: Already enabled"
    echo "  • Check status: systemctl status $APP_NAME"
    echo
    echo "📊 ${BOLD}Optimizations Applied:${NC}"
    echo "  • Steam Deck Model: $MODEL"
    echo "  • Compilation Threads: $([ "$MODEL" = "OLED" ] && echo 6 || echo 4)"
    echo "  • Memory Limit: $([ "$MODEL" = "OLED" ] && echo "2.5GB" || echo "2GB")"
    echo "  • CPU Quota: $([ "$MODEL" = "OLED" ] && echo "60%" || echo "50%")"
    echo "  • Target Architecture: AMD Zen 2 (znver2)"
    echo
    echo "📁 ${BOLD}Configuration:${NC}"
    echo "  • Settings: ~/.config/$APP_NAME/"
    echo "  • Cache: ~/.cache/$APP_NAME/"
    echo "  • Logs: journalctl -u $APP_NAME"
    echo
    echo "🔧 ${BOLD}Troubleshooting:${NC}"
    echo "  • Validate install: $CURRENT_DIR/validate_installation.sh"
    echo "  • Check dependencies: $CURRENT_DIR/check_dependencies.sh"
    echo "  • View logs: tail -f ~/.cache/$APP_NAME/launcher.log"
    echo
    
    read -p "Start the background service now? [Y/n]: " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Nn]$ ]]; then
        sudo systemctl start "$APP_NAME.service"
        log_success "Background service started"
    fi
    
    echo
    log_info "🎉 Installation complete! All GitHub download issues resolved!"
    log_info "Enjoy enhanced shader compilation on your Steam Deck!"
}

# Uninstall function (for completeness)
uninstall() {
    log_header "🗑️  Uninstalling Shader Predictive Compiler"
    
    echo "This will remove:"
    echo "  • Application files"
    echo "  • Desktop entries"
    echo "  • Background service"
    echo "  • Configuration files (optional)"
    echo
    read -p "Are you sure you want to uninstall? [y/N]: " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        log_info "Uninstall cancelled"
        exit 0
    fi
    
    # Stop and disable service
    sudo systemctl stop "$APP_NAME.service" 2>/dev/null || true
    sudo systemctl disable "$APP_NAME.service" 2>/dev/null || true
    
    # Remove files
    sudo rm -rf "$INSTALL_DIR"
    sudo rm -f "$DESKTOP_FILE"
    sudo rm -f "$SYSTEMD_SERVICE"
    
    # Ask about user config
    read -p "Remove user configuration and settings? [y/N]: " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        rm -rf "$HOME/.config/$APP_NAME"
    fi
    
    # Ask about cache
    read -p "Remove shader cache? (This will free disk space) [y/N]: " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        rm -rf "$HOME/.cache/$APP_NAME"
        log_success "Cache removed"
    fi
    
    sudo systemctl daemon-reload
    
    log_success "Shader Predictive Compiler uninstalled"
}

# Help function
show_help() {
    echo "Shader Predictive Compiler Installer with Integrated GitHub Fixes"
    echo
    echo "This installer automatically fixes all common GitHub download issues:"
    echo "  • Line ending problems (CRLF → LF)"
    echo "  • File permission issues"
    echo "  • Shebang line errors"  
    echo "  • Missing files and symlinks"
    echo
    echo "Usage: $0 [OPTIONS]"
    echo
    echo "Options:"
    echo "  --uninstall    Remove the application completely"
    echo "  --help, -h     Show this help message"
    echo "  --fix-only     Only apply GitHub download fixes, don't install"
    echo
    echo "Default action is to fix all issues and install the application."
}

# Apply fixes only (without installation)
fix_only() {
    show_banner
    log_info "Applying GitHub download fixes only..."
    echo
    
    fix_line_endings
    fix_file_permissions
    fix_shebang_lines
    generate_missing_files
    create_missing_symlinks
    
    if validate_critical_files; then
        echo
        log_success "All GitHub download issues have been fixed!"
        log_info "You can now run: ./install (or this script without --fix-only)"
    else
        echo
        log_error "Some critical files are still missing"
        log_info "This may indicate an incomplete download"
        exit 1
    fi
}

# =============================================================================
# MAIN EXECUTION
# =============================================================================

main() {
    case "${1:-}" in
        --uninstall)
            show_banner
            check_permissions
            uninstall
            ;;
        --help|-h)
            show_help
            ;;
        --fix-only)
            fix_only
            ;;
        *)
            show_banner
            check_permissions
            
            log_info "Starting installation with integrated GitHub download fixes..."
            echo
            
            # STEP 1: Apply all GitHub download fixes
            log_header "🔧 STEP 1: Applying GitHub Download Fixes"
            fix_line_endings
            fix_file_permissions  
            fix_shebang_lines
            generate_missing_files
            create_missing_symlinks
            
            # STEP 2: Validate critical files
            if ! validate_critical_files; then
                log_error "Installation cannot continue with missing files"
                exit 1
            fi
            
            # STEP 3: System detection and validation
            log_header "🔍 STEP 2: System Detection and Validation"
            detect_steam_deck
            check_dependencies
            
            # STEP 4: Installation
            log_header "🚀 STEP 3: Installing Application"
            install_application
            create_desktop_entry
            create_systemd_service
            setup_user_config
            setup_steam_integration
            
            # STEP 5: Completion
            installation_complete
            ;;
    esac
}

# Run main function with all arguments
main "$@"