{
  "version": "1.0",
  "ui_settings": {
    "window_width": 800,
    "window_height": 600,
    "auto_start_analysis": false,
    "show_advanced_options": false,
    "theme": "default"
  },
  "compilation_settings": {
    "max_parallel_threads": 4,
    "optimization_level": 2,
    "target_architecture": "znver2",
    "enable_half_precision": true,
    "use_async_compilation": true,
    "priority_boost_factor": 1.2
  },
  "cache_settings": {
    "cache_location": "~/.cache/shader-predict-compile",
    "max_cache_size_gb": 5,
    "cleanup_threshold_days": 30,
    "enable_compression": true,
    "cache_efficiency_target": 0.85
  },
  "system_settings": {
    "enable_thermal_throttling": true,
    "enable_battery_awareness": true,
    "max_cpu_usage_percent": 50,
    "max_memory_usage_mb": 2048,
    "background_priority": true
  },
  "steam_integration": {
    "auto_detect_steam_path": true,
    "steam_library_path": "~/.steam/steam",
    "integrate_with_fossilize": true,
    "monitor_game_launches": true,
    "auto_compile_threshold": 5
  },
  "steam_deck_optimizations": {
    "detect_model_automatically": true,
    "lcd_optimizations": {
      "conservative_power_usage": true,
      "thermal_management": true,
      "compilation_threads": 4,
      "memory_limit_mb": 2048
    },
    "oled_optimizations": {
      "enhanced_gpu_flags": true,
      "variable_rate_shading": true,
      "compilation_threads": 6,
      "memory_limit_mb": 2560
    }
  },
  "logging": {
    "log_level": "INFO",
    "enable_file_logging": true,
    "log_rotation_size_mb": 10,
    "max_log_files": 5
  }
}