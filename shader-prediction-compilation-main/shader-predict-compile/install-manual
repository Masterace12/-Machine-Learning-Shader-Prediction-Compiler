#!/bin/bash

# Manual Installation Script for SteamOS with pacman issues
# This bypasses pacman and uses pip for all Python dependencies

set -e

# Configuration
APP_NAME="shader-predict-compile"
INSTALL_DIR="/opt/${APP_NAME}"
DESKTOP_FILE="/usr/share/applications/${APP_NAME}.desktop"
CURRENT_DIR="$(dirname "$(readlink -f "$0")")"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# Logging functions
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_header() { echo -e "${BOLD}${BLUE}$1${NC}"; }

# Check if running as root
check_permissions() {
    if [[ $EUID -eq 0 ]]; then
        log_error "Do not run this installer as root!"
        log_info "The installer will ask for sudo when needed."
        exit 1
    fi
}

# Banner
show_banner() {
    clear
    echo -e "${BOLD}${BLUE}"
    echo "╔═══════════════════════════════════════════════════════════════╗"
    echo "║              SHADER PREDICTIVE COMPILER                      ║"
    echo "║                Manual Installation                            ║"
    echo "║                                                               ║"
    echo "║  This installer bypasses pacman and uses pip only            ║"
    echo "╚═══════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
    echo
}

# Install Python dependencies via pip
install_python_deps() {
    log_header "🐍 Installing Python Dependencies"
    
    # Install dependencies with pip
    log_info "Installing numpy and psutil via pip..."
    python3 -m pip install --user numpy psutil PyGObject || {
        log_warning "Some packages failed to install via pip"
        log_info "The application will run with reduced functionality"
    }
    
    # Verify what we have
    log_info "Checking installed packages..."
    
    if python3 -c "import numpy" &>/dev/null; then
        log_success "numpy: Available"
    else
        log_warning "numpy: Not available (advanced analysis features will be limited)"
    fi
    
    if python3 -c "import psutil" &>/dev/null; then
        log_success "psutil: Available"
    else
        log_warning "psutil: Not available (system monitoring will be limited)"
    fi
    
    if python3 -c "import gi; gi.require_version('Gtk', '3.0')" &>/dev/null 2>&1; then
        log_success "GTK: Available"
    else
        log_warning "GTK: Not available (GUI may not work)"
        log_info "Try: flatpak install --user org.freedesktop.Platform.GL.default//22.08"
    fi
    
    echo
}

# Install application
install_application() {
    log_header "🚀 Installing Application"
    
    # Create directories
    sudo mkdir -p "$INSTALL_DIR"
    sudo mkdir -p "$(dirname "$DESKTOP_FILE")"
    
    # Copy application files
    log_info "Copying application files..."
    sudo cp -r "$CURRENT_DIR/src" "$INSTALL_DIR/"
    sudo cp -r "$CURRENT_DIR/ui" "$INSTALL_DIR/"
    sudo cp -r "$CURRENT_DIR/config" "$INSTALL_DIR/"
    sudo cp "$CURRENT_DIR/README.md" "$INSTALL_DIR/"
    
    # Create launcher script
    sudo tee "$INSTALL_DIR/launcher.sh" > /dev/null << 'EOF'
#!/bin/bash
cd /opt/shader-predict-compile
export PYTHONPATH="/opt/shader-predict-compile/src:$PYTHONPATH"
export PATH="$HOME/.local/bin:$PATH"
export MESA_VK_DEVICE_SELECT="1002:163f"
export RADV_PERFTEST="aco,nggc"
python3 ui/main_window.py "$@"
EOF
    
    sudo chmod +x "$INSTALL_DIR/launcher.sh"
    sudo chmod +x "$INSTALL_DIR/ui/main_window.py"
    sudo chmod +x "$INSTALL_DIR/src/background_service.py"
    
    # Create simple icon
    sudo tee "$INSTALL_DIR/icon.png" > /dev/null << 'EOF'
# Simple placeholder icon
EOF
    
    log_success "Application files installed"
    echo
}

# Create desktop entry
create_desktop_entry() {
    log_header "🖥️  Creating Desktop Integration"
    
    sudo tee "$DESKTOP_FILE" > /dev/null << EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=Shader Predictive Compiler
Comment=Enhance shader compilation for Steam games on Steam Deck
Icon=$INSTALL_DIR/icon.png
Exec=$INSTALL_DIR/launcher.sh
Terminal=false
Categories=Game;Utility;System;
Keywords=shader;steam;deck;fossilize;compile;performance;optimization;
StartupNotify=true
X-Steam-Library-Capsule=$INSTALL_DIR/icon.png
X-Steam-Controller-Template=Desktop
EOF
    
    log_success "Desktop entry created"
    echo
}

# Setup user config
setup_user_config() {
    log_header "👤 Setting Up User Configuration"
    
    # Create user directories
    mkdir -p "$HOME/.config/$APP_NAME"
    mkdir -p "$HOME/.cache/$APP_NAME"
    
    # Copy default configuration
    cp "$CURRENT_DIR/config/default_settings.json" "$HOME/.config/$APP_NAME/settings.json"
    
    # Create optimizations config
    cat > "$HOME/.config/$APP_NAME/optimizations.json" << EOF
{
    "steam_deck_model": "Unknown",
    "steamos_version": "3.7.13",
    "detected_at": "$(date -Iseconds)",
    "manual_install": true,
    "optimizations": {
        "max_parallel_compiles": 4,
        "memory_limit_mb": 2048,
        "enable_enhanced_features": false
    }
}
EOF
    
    log_success "User configuration created"
    echo
}

# Test installation
test_installation() {
    log_header "🧪 Testing Installation"
    
    log_info "Testing application launch..."
    
    # Test if the application can start
    if timeout 5 "$INSTALL_DIR/launcher.sh" --help &>/dev/null; then
        log_success "Application launches successfully"
    else
        log_warning "Application may have issues - check dependencies"
        log_info "Try running: $INSTALL_DIR/launcher.sh"
    fi
    
    echo
}

# Installation complete
installation_complete() {
    log_header "✅ Manual Installation Complete!"
    
    echo -e "${GREEN}Shader Predictive Compiler has been installed!${NC}"
    echo
    echo "🎮 ${BOLD}How to use:${NC}"
    echo "  • Gaming Mode: Library → Non-Steam → Shader Predictive Compiler"
    echo "  • Desktop Mode: Applications → Games → Shader Predictive Compiler"
    echo "  • Command line: $INSTALL_DIR/launcher.sh"
    echo
    echo "⚠️  ${BOLD}Note:${NC}"
    echo "  • This is a manual installation bypassing pacman"
    echo "  • Some features may be limited due to missing system packages"
    echo "  • The application is designed to work with reduced functionality"
    echo
    echo "🔧 ${BOLD}If you have issues:${NC}"
    echo "  • Try: flatpak install --user org.freedesktop.Platform.GL.default//22.08"
    echo "  • Or: python3 -m pip install --user numpy psutil PyGObject"
    echo
    echo "🗑️  ${BOLD}To uninstall:${NC}"
    echo "  • sudo rm -rf $INSTALL_DIR"
    echo "  • sudo rm -f $DESKTOP_FILE"
    echo "  • rm -rf ~/.config/$APP_NAME ~/.cache/$APP_NAME"
    echo
    
    log_info "Installation complete! The application is ready to use."
}

# Main execution
main() {
    show_banner
    check_permissions
    install_python_deps
    install_application
    create_desktop_entry
    setup_user_config
    test_installation
    installation_complete
}

# Run main function
main "$@"